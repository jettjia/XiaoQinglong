{
    "endpoint": "http://localhost:18080/run",
    "model": {
        "provider": "openai",
        "name": "${OPENAI_MODEL}",
        "api_key": "${OPENAI_API_KEY}",
        "api_base": "${OPENAI_BASE_URL}"
    },
    "system_prompt": "你是一个图片生成助手，根据用户描述生成图片。返回图片URL或base64。",
    "user_message": "生成一张订单确认的图片，包含订单号ORD-20240315-001",
    "tools": [],
    "a2a": [],
    "mcps": [],
    "sandbox": {
        "enabled": false
    },
    "options": {
        "temperature": 0.7,
        "max_tokens": 2000,
        "max_iterations": 10,
        "stream": false,
        "response_schema": {
            "type": "image"
        }
    },
    "skills": [],
    "context": {}
}
