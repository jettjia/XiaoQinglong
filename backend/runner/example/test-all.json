{
    "endpoint": "http://localhost:18080/run",
    "models": {
        "default": {
            "provider": "openai",
            "name": "${OPENAI_MODEL}",
            "api_key": "${OPENAI_API_KEY}",
            "api_base": "${OPENAI_BASE_URL}"
        },
        "rewrite": {
            "provider": "openai",
            "name": "${OPENAI_MODEL_MINI}",
            "api_key": "${OPENAI_API_KEY}",
            "api_base": "${OPENAI_BASE_URL}"
        },
        "skill": {
            "provider": "openai",
            "name": "${OPENAI_MODEL}",
            "api_key": "${OPENAI_API_KEY}",
            "api_base": "${OPENAI_BASE_URL}"
        },
        "summarize": {
            "provider": "openai",
            "name": "${OPENAI_MODEL_MINI}",
            "api_key": "${OPENAI_API_KEY}",
            "api_base": "${OPENAI_BASE_URL}"
        }
    },
    "system_prompt": "你是一个智能助手，擅长使用工具和技能来回答用户问题。如果需要查询订单，请使用 get_order_detail 工具。如果需要上传文件到S3，可以使用 s3-upload 技能。",
    "user_message": "查询订单号12345的详情",
    "tools": [
        {
            "type": "http",
            "name": "get_order_detail",
            "description": "根据订单号获取订单详情",
            "endpoint": "http://localhost:28081/v1/orders/{order_no}",
            "method": "GET",
            "headers": {
                "Content-Type": "application/json"
            },
            "risk_level": "high"
        },
        {
            "type": "http",
            "name": "get_product_info",
            "description": "获取产品信息",
            "endpoint": "http://localhost:8081/products/{product_id}",
            "method": "GET",
            "headers": {},
            "risk_level": "low"
        },
        {
            "type": "http",
            "name": "send_notification",
            "description": "发送通知给用户",
            "endpoint": "http://localhost:8081/notify",
            "method": "POST",
            "headers": {
                "Content-Type": "application/json"
            },
            "risk_level": "medium"
        },
        {
            "type": "delegate",
            "name": "delegate_to_agent",
            "description": "委托任务给子Agent执行，子Agent会独立运行并返回结构化结果（同步执行，阻塞等待）",
            "risk_level": "low"
        },
        {
            "type": "http",
            "name": "spawn",
            "description": "异步启动子Agent任务，立即返回task_id（推荐用于并行执行多个任务）",
            "endpoint": "内置工具",
            "method": "内置",
            "risk_level": "low"
        },
        {
            "type": "http",
            "name": "collect_task",
            "description": "收集异步子Agent任务的结果，等待任务完成并返回输出",
            "endpoint": "内置工具",
            "method": "内置",
            "risk_level": "low"
        },
        {
            "type": "http",
            "name": "list_tasks",
            "description": "列出所有子Agent任务及其状态",
            "endpoint": "内置工具",
            "method": "内置",
            "risk_level": "low"
        },
        {
            "type": "http",
            "name": "cancel_task",
            "description": "取消一个正在运行的子Agent任务",
            "endpoint": "内置工具",
            "method": "内置",
            "risk_level": "medium"
        }
    ],
    "a2a": [
        {
            "name": "payment_agent",
            "endpoint": "http://localhost:28080/a2a",
            "headers": {},
            "risk_level": "medium"
        },
        {
            "name": "order_agent",
            "endpoint": "http://localhost:28081/a2a",
            "headers": {},
            "risk_level": "high"
        }
    ],
    "mcps": [
        {
            "name": "weather",
            "transport": "stdio",
            "command": "go",
            "args": [
                "run",
                "/home/jett/aishu/XiaoQinglong/mock/mcp"
            ],
            "env": {},
            "risk_level": "low"
        },
        {
            "name": "filesystem",
            "transport": "http",
            "endpoint": "http://localhost:8090/mcp",
            "headers": {
                "Authorization": "Bearer token"
            },
            "risk_level": "high"
        }
    ],
    "sandbox": {
        "enabled": true,
        "mode": "docker",
        "image": "sandbox-code-interpreter:v1.0.3",
        "workdir": "/workspace",
        "timeout_ms": 120000,
        "network": "bridge",
        "env": {
            "PATH": "/usr/local/bin:/usr/bin:/bin"
        },
        "limits": {
            "cpu": "0.5",
            "memory": "512m"
        }
    },
    "options": {
        "temperature": 0.7,
        "max_tokens": 2000,
        "max_iterations": 10,
        "max_tool_calls": 20,
        "max_a2a_calls": 5,
        "max_total_tokens": 50000,
        "stream": true,
        "retry": {
            "max_attempts": 3,
            "initial_delay_ms": 1000,
            "max_delay_ms": 10000,
            "backoff_multiplier": 2.0,
            "retryable_errors": [
                "timeout",
                "rate_limit",
                "server_error"
            ]
        },
        "routing": {
            "default_model": "default",
            "rewrite_prompt": "请优化以下用户Query，使其更加清晰、准确，便于理解和执行。只返回优化后的Query，不要其他内容。",
            "summarize_prompt": "请总结以下内容，提取关键信息，保持简洁。只返回总结内容，不要其他内容。"
        },
        "approval_policy": {
            "enabled": true,
            "risk_threshold": "medium",
            "auto_approve": [
                "get_product_info"
            ]
        },
        "checkpoint_id": "test-run-001",
        "response_schema": {
            "type": "text",
            "version": "1.0",
            "strict": true,
            "schema": {
                "type": "object",
                "properties": {
                    "content": {
                        "type": "string",
                        "description": "回复用户的文本内容"
                    },
                    "action": {
                        "type": "object",
                        "properties": {
                            "type": {
                                "type": "string",
                                "enum": [
                                    "none",
                                    "form",
                                    "link",
                                    "calendar",
                                    "location"
                                ]
                            },
                            "data": {}
                        }
                    },
                    "card": {
                        "type": "object",
                        "properties": {
                            "title": {
                                "type": "string"
                            },
                            "sections": {
                                "type": "array"
                            },
                            "actions": {
                                "type": "array"
                            }
                        }
                    }
                }
            }
        }
    },
    "skills": [
        {
            "id": "s3-upload",
            "name": "S3上传下载",
            "description": "用于上传和下载S3对象存储中的文件",
            "instruction": "你是一个S3操作助手，可以帮助用户上传文件到S3或从S3下载文件。",
            "scope": "both",
            "trigger": "manual",
            "entry_script": "python3 scripts/s3_upload.py",
            "file_path": "s3-upload",
            "risk_level": "medium"
        },
        {
            "id": "query-order",
            "name": "订单查询",
            "description": "查询用户订单状态和详情",
            "instruction": "你是一个订单查询助手，可以帮助用户查询订单状态、订单详情等信息。",
            "scope": "query",
            "trigger": "auto",
            "entry_script": "python3 scripts/query_order.py",
            "file_path": "query-order",
            "risk_level": "low"
        },
        {
            "id": "data-export",
            "name": "数据导出",
            "description": "导出数据为Excel或CSV格式",
            "instruction": "你是一个数据导出助手，可以帮助用户导出各种格式的数据。",
            "scope": "export",
            "trigger": "manual",
            "entry_script": "python3 scripts/data_export.py",
            "file_path": "data-export",
            "risk_level": "high"
        }
    ],
    "sub_agents": [
        {
            "id": "researcher",
            "name": "研究Agent",
            "description": "负责信息检索、文献研究和数据分析",
            "prompt": "你是一个研究助手，擅长搜索和分析信息。根据用户的问题，进行深入研究并返回结构化的研究结果。",
            "max_iterations": 5,
            "timeout_ms": 120000
        },
        {
            "id": "coder",
            "name": "编码Agent",
            "description": "负责代码编写、调试和代码审查",
            "prompt": "你是一个编程专家，擅长代码开发。当需要编写代码时使用此Agent。",
            "max_iterations": 10,
            "timeout_ms": 300000
        },
        {
            "id": "reviewer",
            "name": "审核Agent",
            "description": "负责代码和文档的质量审核",
            "prompt": "你是一个审核专家，负责检查代码质量和一致性。",
            "max_iterations": 3,
            "timeout_ms": 60000
        }
    ],
    "context": {
