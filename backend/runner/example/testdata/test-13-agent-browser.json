{
    "endpoint": "http://localhost:18080/run",
    "models": {
        "default": {
            "provider": "openai",
            "name": "${OPENAI_MODEL}",
            "api_key": "${OPENAI_API_KEY}",
            "api_base": "${OPENAI_BASE_URL}"
        },
        "rewrite": {
            "provider": "openai",
            "name": "${OPENAI_MODEL_MINI}",
            "api_key": "${OPENAI_API_KEY}",
            "api_base": "${OPENAI_BASE_URL}"
        },
        "skill": {
            "provider": "openai",
            "name": "${OPENAI_MODEL}",
            "api_key": "${OPENAI_API_KEY}",
            "api_base": "${OPENAI_BASE_URL}"
        },
        "summarize": {
            "provider": "openai",
            "name": "${OPENAI_MODEL_MINI}",
            "api_key": "${OPENAI_API_KEY}",
            "api_base": "${OPENAI_BASE_URL}"
        }
    },
    "system_prompt": "你是一个浏览器自动化助手。你必须且只能使用 agent-browser skill 来完成任务。\n\n【强制规则】\n1. 禁止使用 WebFetch、WebSearch 等 HTTP 请求工具获取网页数据\n2. 禁止使用 Bash 工具执行 curl、wget 等命令\n3. 所有网页操作必须通过 agent-browser CLI 完成\n\n【agent-browser 使用流程】\n1. agent-browser open <url> - 打开网页\n2. agent-browser snapshot -i --json - 获取页面元素快照\n3. agent-browser click/fill @eN - 点击或填写表单\n4. agent-browser get text/attr @eN --json - 提取数据\n5. agent-browser screenshot - 截图\n\n请完成以下任务：通过浏览器访问百度，搜索'北京天气'，提取北京今天的温度数据并告诉我结果。",
    "user_message": "打开浏览器，访问百度，搜索'北京天气'，然后告诉我北京今天的温度是多少",
    "tools": [],
    "a2a": [],
    "mcps": [],
    "sandbox": {
        "enabled": false,
        "mode": "local",
        "image": "alpine:latest",
        "workdir": "/workspace",
        "timeout_ms": 120000,
        "network": "bridge",
        "env": {
            "PATH": "/root/bin:/usr/local/bin:/usr/bin:/bin:/root/.nvm/versions/node/v22.17.1/bin",
            "AGENT_BROWSER_CDP": "9225"
        },
        "limits": {
            "cpu": "1.0",
            "memory": "512m"
        }
    },
    "options": {
        "temperature": 0.7,
        "max_tokens": 4000,
        "max_iterations": 20,
        "max_tool_calls": 30,
        "max_a2a_calls": 5,
        "max_total_tokens": 80000,
        "stream": false,
        "retry": {
            "max_attempts": 2,
            "initial_delay_ms": 1000,
            "max_delay_ms": 10000,
            "backoff_multiplier": 2.0,
            "retryable_errors": [
                "timeout",
                "rate_limit",
                "server_error"
            ]
        },
        "routing": {
            "default_model": "default",
            "rewrite_prompt": "请优化以下用户Query，使其更加清晰、准确，便于理解和执行。只返回优化后的Query，不要其他内容。",
            "summarize_prompt": "请总结以下内容，提取关键信息，保持简洁。只返回总结内容，不要其他内容。"
        },
        "approval_policy": {
            "enabled": false,
            "risk_threshold": "medium"
        },
        "checkpoint_id": "test-browser-001"
    },
    "skills": [
        {
            "id": "agent-browser",
            "name": "浏览器自动化",
            "description": "网页搜索、打开网站、浏览器操作、获取网页数据、点击网页元素、填表提交、抓取网页内容",
            "instruction": "使用 agent-browser CLI 进行浏览器自动化操作。通过 bash 工具执行 agent-browser 命令。",
            "scope": "both",
            "trigger": "auto",
            "risk_level": "medium"
        }
    ],
    "sub_agents": [],
    "context": {
        "session_id": "sess_browser_001",
        "user_id": "user_001",
        "channel_id": "test",
        "skills_dir": "/home/jett/self/XiaoQinglong/skills",
        "variables": {}
    },
    "knowledge_bases": [],
    "files": []
}