{
    "endpoint": "http://localhost:18080/run",
    "models": {
        "default": {
            "provider": "openai",
            "name": "${OPENAI_MODEL}",
            "api_key": "${OPENAI_API_KEY}",
            "api_base": "${OPENAI_BASE_URL}"
        }
    },
    "system_prompt": "你是连续运行模式下的自主 Agent。请完成以下任务：\n1. 首先查看当前时间\n2. 然后计算当前小时乘以 7 的值\n3. 如果结果大于 30，返回 \"LOOP_COMPLETE\"\n\n每次迭代执行一个步骤。",
    "user_message": "",
    "messages": [],
    "tools": [
        {
            "type": "http",
            "name": "get_time",
            "description": "获取当前时间",
            "endpoint": "http://worldtimeapi.org/api/timezone/Asia/Shanghai",
            "method": "GET",
            "headers": {},
            "risk_level": "low"
        }
    ],
    "a2a": [],
    "mcps": [],
    "sandbox": {
        "enabled": false
    },
    "options": {
        "temperature": 0.7,
        "max_tokens": 1500,
        "max_tool_calls": 5,
        "stream": false,
        "loop_interval": "3s",
        "loop_max_iterations": 5,
        "loop_stop_condition": "LOOP_COMPLETE"
    },
    "skills": [],
    "sub_agents": [],
    "context": {
        "session_id": "sess_loop_003",
        "user_id": "user_loop_003",
        "channel_id": "test"
    },
    "knowledge_bases": [],
    "files": []
}