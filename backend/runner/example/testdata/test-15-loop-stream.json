{
    "endpoint": "http://localhost:18080/run",
    "models": {
        "default": {
            "provider": "openai",
            "name": "${OPENAI_MODEL}",
            "api_key": "${OPENAI_API_KEY}",
            "api_base": "${OPENAI_BASE_URL}"
        }
    },
    "system_prompt": "你是连续运行模式下的自主 Agent。请完成以下任务：\n1. 先计算 10+5 的结果\n2. 将结果乘以 3\n3. 如果最终结果大于 40，返回 \"LOOP_COMPLETE\"\n\n每轮迭代只执行一个步骤。",
    "user_message": "",
    "messages": [],
    "tools": [],
    "a2a": [],
    "mcps": [],
    "sandbox": {
        "enabled": false
    },
    "options": {
        "temperature": 0.7,
        "max_tokens": 1000,
        "stream": true,
        "loop_interval": "2s",
        "loop_max_iterations": 5,
        "loop_stop_condition": "LOOP_COMPLETE"
    },
    "skills": [],
    "sub_agents": [],
    "context": {
        "session_id": "sess_loop_002",
        "user_id": "user_loop_002",
        "channel_id": "test"
    },
    "knowledge_bases": [],
    "files": []
}