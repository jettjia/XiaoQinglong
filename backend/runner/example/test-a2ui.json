            "method": "GET",
            "headers": {
                "Content-Type": "application/json"
            },
            "risk_level": "medium"
        },
        {
            "type": "http",
            "name": "get_product_info",
            "description": "获取产品信息",
            "endpoint": "http://localhost:8081/products/{product_id}",
            "method": "GET",
            "headers": {},
            "risk_level": "low"
        }
