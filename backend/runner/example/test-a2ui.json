    "a2a": [
        {
            "name": "payment_agent",
            "endpoint": "http://localhost:28080/a2a",
            "headers": {}
        }
    ],
    "mcps": [],
    "sandbox": {
        "enabled": false,
        "mode": "docker",
        "image": "sandbox-code-interpreter:v1.0.3",
        "workdir": "/workspace",
        "timeout_ms": 120000,
        "env": {
            "PATH": "/usr/local/bin:/usr/bin:/bin"
        }
    },
    "options": {
        "temperature": 0.7,
        "max_tokens": 2000,
        "max_iterations": 10,
        "stream": true
